<button
  id="scrollToTopBtn"
  class="fixed bottom-8 right-8 w-14 h-14 bg-red-600 text-white rounded-full shadow-lg flex items-center justify-center hover:bg-red-700 hover:-translate-y-1 transition-all duration-300 z-50 opacity-0 translate-y-4 pointer-events-none"
  aria-label="Scroll to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
    ></path>
  </svg>
</button>

<style is:global>
  [data-motion] {
    opacity: 0;
    transition-duration: 0.5s;
  }
  [data-motion="fade-in"] {
    transition-property: opacity;
    transition-timing-function: ease-in-out;
  }
  [data-motion="fade-up"] {
    transform: translateY(40px);
    transition-property: opacity, transform;
    transition-timing-function: cubic-bezier(0.17, 0.55, 0.55, 1);
  }
  [data-motion="fade-left"] {
    transform: translateX(40px);
    transition-property: opacity, transform;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-motion="fade-right"] {
    transform: translateX(-40px);
    transition-property: opacity, transform;
    transition-timing-function: ease-out;
  }
  [data-motion="zoom-in"] {
    transform: scale(0.9);
    transition-property: opacity, transform;
    transition-timing-function: ease-out;
  }
  [data-motion].is-visible {
    opacity: 1;
    transform: none;
  }

  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Premium Magazine Styling for Rich Text Content */
  .editorial-prose p {
    margin-bottom: 1.5rem;
  }
  .editorial-prose p:last-child {
    margin-bottom: 0;
  }

  /* Bold Formatting */
  .editorial-prose strong {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 800;
    color: #111827; /* Tailwind gray-900 */
  }

  /* Italic Formatting */
  .editorial-prose em {
    font-style: italic;
    color: #374151; /* Tailwind gray-700 */
  }

  /* Standard CMS Blockquote Style */
  .editorial-prose blockquote {
    font-style: italic;
    color: #4b5563; /* Tailwind gray-600 */
    padding-left: 1.5rem;
    border-left: 4px solid #dc2626; /* Tailwind red-600 */
    margin: 2rem 0;
  }
  .editorial-prose blockquote p {
    font-size: 1.125rem;
    line-height: 1.75;
  }

  /* Dark Mode Content Overrides (Section 8) */
  .editorial-prose.editorial-prose-dark blockquote {
    color: #facc15; /* Tailwind yellow-400 */
    border-left: 4px solid rgba(250, 204, 21, 0.4);
  }
  .editorial-prose.editorial-prose-dark strong {
    color: #f3f4f6;
  }
  .editorial-prose.editorial-prose-dark em {
    color: #d1d5db;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            if (el.dataset.delay) el.style.transitionDelay = el.dataset.delay;
            el.classList.add("is-visible");
            // } else {
            //   if (entry.boundingClientRect.top > 0) {
            //     el.style.transitionDelay = "0ms";
            //     el.classList.remove("is-visible");
            //   }
            // }
          } else {
            el.style.transitionDelay = "0ms";
            el.classList.remove("is-visible");
          }
        });
      },
      { rootMargin: "0px 0px 50px 0px", threshold: 0 },
    );

    document.querySelectorAll("[data-motion]").forEach((htmlElement) => {
      const el = htmlElement as HTMLElement;
      if (el.style.animationDelay) {
        const ms = parseInt(el.style.animationDelay, 10);
        el.dataset.delay = `${ms * 0.25}ms`;
      }
      observer.observe(el);
    });

    const scrollToTopBtn = document.getElementById("scrollToTopBtn");
    if (scrollToTopBtn) {
      window.addEventListener("scroll", () => {
        if (window.scrollY > 400) {
          scrollToTopBtn.classList.remove(
            "opacity-0",
            "translate-y-4",
            "pointer-events-none",
          );
          scrollToTopBtn.classList.add("opacity-100", "translate-y-0");
        } else {
          scrollToTopBtn.classList.add(
            "opacity-0",
            "translate-y-4",
            "pointer-events-none",
          );
          scrollToTopBtn.classList.remove(
            "opacity-100",
            "translate-y-0",
            "hover:-translate-y-1",
          );
        }
      });
      scrollToTopBtn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }

    const rows = document.querySelectorAll(".character-row");
    const placeholder = document.getElementById("story-placeholder");
    const storyContents = document.querySelectorAll(".story-content");

    rows.forEach((row) => {
      row.addEventListener("click", () => {
        const targetIndex = row.getAttribute("data-index");
        const targetContent = document.getElementById(
          `story-content-${targetIndex}`,
        );

        if (row.classList.contains("is-active")) {
          row.classList.remove("is-active");
          if (targetContent) {
            targetContent.classList.add("opacity-0", "translate-y-4");
            setTimeout(() => targetContent.classList.add("hidden"), 300);
          }
          placeholder?.classList.remove("hidden", "opacity-0");
          return;
        }

        rows.forEach((r) => r.classList.remove("is-active"));
        storyContents.forEach((content) => {
          content.classList.add("hidden", "opacity-0", "translate-y-4");
        });

        row.classList.add("is-active");
        placeholder?.classList.add("hidden");

        if (targetContent) {
          targetContent.classList.remove("hidden");
          const scrollableArea =
            targetContent.querySelector(".overflow-y-auto");
          if (scrollableArea) scrollableArea.scrollTop = 0;
          requestAnimationFrame(() => {
            targetContent.classList.remove("opacity-0", "translate-y-4");
          });
        }
      });
    });

    const scrollTracker = document.getElementById("scroll-tracker");
    if (scrollTracker) {
      const analyticsObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              if (
                typeof window !== "undefined" &&
                typeof (window as any).gtag === "function"
              ) {
                (window as any).gtag("event", "article_read_complete", {
                  event_category: "engagement",
                  event_label: "Reached 80 percent",
                });
                console.log("Analytics: Reader reached 80%!");
              }
              analyticsObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      analyticsObserver.observe(scrollTracker);
    }
  });
</script>
