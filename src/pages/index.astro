---
import Layout from "../layouts/Layout.astro";
import homepage from "../content/homepage/data.json";

// Type definitions for your layout arrays
type TimelineItem = {
  year: string;
  text: string;
  image: string | null;
};

// Explicitly cast the timeline array as TimelineItem[]
const timelineData = (homepage.timeline || []) as TimelineItem[];

const col1Items = timelineData.filter((_, i) => i % 2 === 0);
const col2Items = timelineData.filter((_, i) => i % 2 === 1);

const col1Rotations = ["-rotate-6", "-rotate-2", "-rotate-3", "-rotate-2"];
const col2Rotations = ["rotate-6", "rotate-4", "rotate-6", "rotate-3"];

function parseParagraphs(text: string | null | undefined) {
  return (text || '').split('\n\n').filter((p) => p.trim() !== '');
}
---

<Layout title={homepage.coverTitle?.replace('\n', ' ')} headerTitle={homepage.headerTitle}>
  <main class="pt-0">
    <!-- Hero / Cover Image Section -->
    <section id="cover-section" class="relative w-full h-[60vh] md:h-[80vh] lg:h-screen min-h-100 overflow-hidden bg-gray-200">
      <div class="absolute inset-0 flex items-center justify-center bg-gray-300" data-motion="fade-in">
        <span class="text-gray-500 font-medium" data-motion="zoom-in" style="animation-delay: 200ms">Hero Image Placeholder</span>
      </div>
    </section>

    <!-- Cover Image Frame Section -->
    <section class="py-12 md:py-20">
      <div class="flex justify-center">
        <div class="w-11/12 md:w-9/12 xl:w-7/12" data-motion="zoom-in">
          <div class="relative items-center justify-center flex p-4">
            <div class="w-full aspect-3/1 bg-gray-300 border-8 md:border-12 border-[#eccb2f] shadow-lg -rotate-2 flex items-center justify-center relative z-10 overflow-hidden" data-motion="fade-right" style="animation-delay: 150ms">
              {homepage.coverImage ? (
                <img src={homepage.coverImage} alt="Cover" class="w-full h-full object-cover" />
              ) : (
                <span class="text-gray-500 font-medium" data-motion="fade-up" style="animation-delay: 450ms">Cover Image Placeholder</span>
              )}
            </div>
            <div class="absolute inset-0 bg-[#eccb2f]/20 rotate-1 border-2 border-dashed border-red-500 rounded-sm" data-motion="fade-in" style="animation-delay: 300ms"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 1 (Intro) -->
    <section class="relative overflow-visible pb-12">
      <div class="absolute right-0 top-10 w-24 h-48 bg-yellow-200/50 rounded-l-full hidden md:block" data-motion="fade-left" style="animation-delay: 200ms"></div>
      <div class="absolute left-0 bottom-10 w-20 h-40 bg-green-200/50 rounded-r-full hidden md:block" data-motion="fade-right" style="animation-delay: 400ms"></div>

      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection1).map((p, i) => {
              const isQuote = p.trim().startsWith('“') || p.trim().startsWith('"');
              return (
                <p data-motion="fade-up" style={`animation-delay: ${i * 150}ms`} class={isQuote ? "italic text-gray-600 pl-4 border-l-4 border-yellow-400" : ""}>
                  {p}
                </p>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Character Introductions (Interactive) -->
    <section class="relative overflow-visible pb-12 bg-gray-50/50 py-12">
      <div class="flex justify-center px-4 mb-8">
        <div class="w-11/12 md:w-8/12 xl:w-6/12 text-center">
          <h2 class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block" data-motion="fade-up">
            {homepage.section2Title}
          </h2>
          {parseParagraphs(homepage.textSection2).map((p, i) => (
            <p class="text-lg text-gray-700 font-serif mb-4" data-motion="fade-up" style={`animation-delay: ${100 + (i * 100)}ms`}>
              {p}
            </p>
          ))}
        </div>
      </div>

      <!-- 3 Columns Interactive Grid -->
      <div class="flex justify-center px-4">
        <div class="w-full md:w-10/12 xl:w-8/12">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {homepage.characters && homepage.characters.map((char, index) => (
              <div 
                class="character-card group relative bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden cursor-pointer hover:shadow-xl transition-all duration-300"
                data-motion="fade-up" 
                style={`animation-delay: ${index * 150}ms`}
              >
                <div class={`${char.color} h-3 w-full`}></div>
                <div class="p-6 text-center z-10 relative bg-white">
                  <div class="w-24 h-24 mx-auto bg-gray-200 rounded-full mb-4 overflow-hidden border-4 border-white shadow-sm">
                    {char.image ? <img src={char.image} alt={char.name} class="w-full h-full object-cover" /> : <span class="text-gray-400 text-xs flex items-center justify-center h-full">Image</span>}
                  </div>
                  <h3 class="text-2xl font-black text-gray-900 mb-1">{char.name}, {char.age}</h3>
                  <p class="text-sm text-gray-500 font-medium">{char.job}</p>
                  
                  <button class="mt-4 px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-800 text-sm font-semibold rounded-full transition-colors toggle-btn">
                    Baca Cerita
                  </button>
                </div>

                <div class="story-panel hidden bg-gray-50 p-6 border-t border-gray-100 text-left">
                  <p class="text-gray-700 font-serif leading-relaxed text-sm">
                    {char.story}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Optional Timeline Section -->
    {homepage.showTimeline && (
      <section class="py-12 md:py-20 relative overflow-hidden mt-8 mb-12 flex justify-center px-4">
        <div class="relative w-full md:w-4/5 lg:w-[60%] max-w-4xl border-4 border-red-600 rounded-[100px] md:rounded-[150px] pt-16 md:pt-24 pb-20 md:pb-28 flex flex-col items-center z-10" data-motion="zoom-in">
          <div class="absolute inset-2 md:inset-3 border-2 border-red-600 rounded-[90px] md:rounded-[140px] pointer-events-none z-0"></div>

          <div class="relative z-10 px-6 md:px-12 text-center max-w-3xl" data-motion="fade-up" style="animation-delay: 200ms">
            <div class="flex justify-center items-center space-x-2 mb-4">
              <span class="block w-12 h-1 bg-red-600 rounded-full"></span>
              <span class="block w-3 h-3 border-2 border-red-600 rounded-full"></span>
              <span class="block w-12 h-1 bg-red-600 rounded-full"></span>
            </div>

            <h2 class="text-4xl md:text-5xl font-serif font-black text-red-600 leading-tight mb-8">
              {homepage.coverTitle?.split('\n').map((line) => (
                <>{line}<br /></>
              ))}
            </h2>

            <p class="text-red-700 font-medium text-sm md:text-base leading-relaxed max-w-2xl mx-auto pb-16">
              {homepage.coverIntro}
            </p>
          </div>

          <div class="w-full relative flex pb-12 z-10">
            <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-12 md:bottom-20 w-1 bg-red-600 z-0" data-motion="fade-in" style="animation-delay: 400ms"></div>

            <div class="w-1/2 flex flex-col items-end gap-y-16 md:gap-y-24">
              {col1Items.map((item, index) => {
                const rotation = col1Rotations[index % col1Rotations.length];
                return (
                  <div class="flex flex-col items-center w-full sm:w-11/12 max-w-[320px] md:max-w-[380px]" data-motion="fade-right" style={`animation-delay: ${100 + (index * 200)}ms`}>
                    <div class="relative w-full max-w-[260px] h-40 md:h-56 mb-6 flex justify-center items-center">
                      <div class={`absolute z-20 w-40 md:w-48 aspect-[4/3] bg-gray-300 border-[4px] md:border-[6px] border-[#eccb2f] ${rotation} shadow-lg flex items-center justify-center overflow-hidden`}>
                        {item.image ? <img src={item.image} alt={item.year} class="w-full h-full object-cover" /> : <span class="text-[10px] md:text-xs text-gray-600 font-medium text-center">Image</span>}
                      </div>
                    </div>
                    <div class="flex w-full items-center">
                      <div class="flex-1"></div>
                      <h3 class="text-3xl md:text-4xl font-black text-red-600 tracking-tight px-4 md:px-6">{item.year}</h3>
                      <div class="flex-1 h-1 bg-red-600 z-10"></div>
                    </div>
                    <div class="w-3 md:w-4 h-3 md:h-4 bg-red-600 rounded-full mt-2 mb-4"></div>
                    <div class="text-center px-4 space-y-3 text-sm md:text-base font-medium text-gray-900 leading-snug">
                      <p>{item.text}</p>
                    </div>
                  </div>
                );
              })}
            </div>

            <div class="w-1/2 flex flex-col items-start gap-y-16 md:gap-y-24 pt-[14rem] md:pt-[20rem]">
              {col2Items.map((item, index) => {
                const rotation = col2Rotations[index % col2Rotations.length];
                return (
                  <div class="flex flex-col items-center w-full sm:w-11/12 max-w-[320px] md:max-w-[380px]" data-motion="fade-left" style={`animation-delay: ${200 + (index * 200)}ms`}>
                    <div class="relative w-full max-w-[260px] h-40 md:h-56 mb-6 flex justify-center items-center">
                      <div class={`absolute z-20 w-40 md:w-48 aspect-[4/3] bg-gray-300 border-[4px] md:border-[6px] border-[#eccb2f] ${rotation} shadow-lg flex items-center justify-center overflow-hidden`}>
                        {item.image ? <img src={item.image} alt={item.year} class="w-full h-full object-cover" /> : <span class="text-[10px] md:text-xs text-gray-600 font-medium text-center">Image</span>}
                      </div>
                    </div>
                    <div class="flex w-full items-center">
                      <div class="flex-1 h-1 bg-red-600 z-10"></div>
                      <h3 class="text-3xl md:text-4xl font-black text-red-600 tracking-tight px-4 md:px-6">{item.year}</h3>
                      <div class="flex-1"></div>
                    </div>
                    <div class="w-3 md:w-4 h-3 md:h-4 bg-red-600 rounded-full mt-2 mb-4"></div>
                    <div class="text-center px-4 space-y-3 text-sm md:text-base font-medium text-gray-900 leading-snug">
                      <p>{item.text}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Section 3 -->
    <section class="relative overflow-visible pb-12 pt-8">
      {homepage.section3Title && (
        <div class="flex justify-center px-4 mb-8">
          <div class="w-11/12 md:w-8/12 xl:w-6/12">
            <h2 class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block" data-motion="fade-right">
              {homepage.section3Title}
            </h2>
          </div>
        </div>
      )}
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection3).map((p, i) => {
              const isQuote = p.trim().startsWith('“') || p.trim().startsWith('"');
              return (
                <p data-motion="fade-up" style={`animation-delay: ${50 + (i * 100)}ms`} class={isQuote ? "italic text-gray-600 pl-4 border-l-4 border-red-500" : ""}>
                  {p}
                </p>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- YouTube Video Section -->
    <section class="py-8 md:py-16 relative">
      <div class="flex justify-center px-4">
        <div class="w-full md:w-10/12" data-motion="zoom-in">
          <div class="relative w-full aspect-video flex items-center justify-center overflow-visible p-4 md:p-8">
            <div class="w-full h-full bg-gray-800 border-8 md:border-16 border-[#eccb2f] shadow-2xl rotate-1 flex items-center justify-center group relative overflow-hidden z-10 hover:rotate-0 transition-transform duration-500">
              {homepage.videoUrl ? (
                <iframe class="w-full h-full absolute inset-0 z-20" src={homepage.videoUrl} title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
              ) : (
                <div class="w-16 h-16 md:w-24 md:h-24 bg-white/90 rounded-full flex items-center justify-center z-20 group-hover:scale-110 transition-transform cursor-pointer shadow-lg">
                  <div class="ml-2 w-0 h-0 border-t-10 border-t-transparent border-l-16 border-l-red-600 border-b-10 border-b-transparent md:border-t-14 md:border-l-24 md:border-b-14"></div>
                </div>
              )}
            </div>
            <div class="absolute inset-4 md:inset-8 bg-[#eccb2f]/30 -rotate-2 rounded z-0" data-motion="fade-in" style="animation-delay: 300ms"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4 -->
    <section class="relative overflow-visible pb-12 bg-stone-50 py-8">
      {homepage.section4Title && (
        <div class="flex justify-center px-4 mb-8">
          <div class="w-11/12 md:w-8/12 xl:w-6/12">
            <h2 class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block" data-motion="fade-right">
              {homepage.section4Title}
            </h2>
          </div>
        </div>
      )}
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection4).map((p, i) => {
              const borderColors = ["", "text-red-600 font-semibold", "text-blue-600 font-semibold", "", "", "text-emerald-600 font-semibold", "text-stone-600 font-semibold"];
              return (
                <p data-motion="fade-left" style={`animation-delay: ${i * 150}ms`} class={borderColors[i] ? `pl-6 ${borderColors[i]}` : ""}>
                  {p}
                </p>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5 -->
    <section class="relative overflow-visible pb-12 pt-8">
      {homepage.section5Title && (
        <div class="flex justify-center px-4 mb-8">
          <div class="w-11/12 md:w-8/12 xl:w-6/12">
            <h2 class="text-3xl md:text-4xl font-black mb-6 border-b-2 border-red-500 pb-2 inline-block" data-motion="zoom-in">
              {homepage.section5Title}
            </h2>
          </div>
        </div>
      )}
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection5).map((p, i) => {
              const hasBg = p.trim().startsWith('“') || p.trim().startsWith('"');
              const extraClass = hasBg && p.includes("eros laoreet") ? "font-medium bg-yellow-50 p-4 rounded-md shadow-sm border-l-4 border-yellow-500" : "";
              return <p data-motion="zoom-in" style={`animation-delay: ${(i + 1) * 100}ms`} class={extraClass}>{p}</p>;
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Graphic Placeholders Section -->
    <section class="py-8 md:py-16 relative bg-zinc-100/60 overflow-hidden">
      <div class="flex justify-center px-4">
        <div class="w-full md:w-10/12">
          <div class="relative w-full h-100 md:h-150 flex items-center justify-center overflow-visible">
            <div class="absolute w-64 h-64 md:w-125 md:h-125 bg-yellow-100 rounded-full flex items-center justify-center z-0 animate-pulse"></div>
            <div class="absolute bottom-20 left-10 w-24 h-24 md:w-32 md:h-32 bg-green-500 rounded-tl-full rounded-br-full rotate-15 opacity-70 z-0"></div>

            <!-- Graphic 2A -->
            <div class="absolute w-56 md:w-96 aspect-4/3 bg-gray-300 border-8 md:border-12 border-[#eccb2f] shadow-lg rotate-4 translate-x-12 translate-y-10 md:translate-x-20 md:translate-y-16 flex items-center justify-center z-10 transition-transform duration-300 hover:scale-105 hover:-rotate-2 hover:z-40 cursor-pointer overflow-hidden" data-motion="fade-left" style="animation-delay: 200ms">
              {homepage.graphic2A ? (
                <img src={homepage.graphic2A} alt="Graphic 2A" class="w-full h-full object-cover" />
              ) : (
                <span class="text-gray-500 font-medium text-xs md:text-sm text-center px-2">Graphic Placeholder 2A</span>
              )}
            </div>

            <!-- Graphic 2B -->
            <div class="absolute w-52 md:w-80 aspect-3/4 bg-gray-400 border-8 md:border-12 border-[#eccb2f] shadow-2xl -rotate-4 -translate-x-16 -translate-y-4 md:-translate-x-28 md:-translate-y-8 flex items-center justify-center z-20 transition-transform duration-300 hover:scale-105 hover:rotate-2 hover:z-40 cursor-pointer overflow-hidden" data-motion="fade-right" style="animation-delay: 400ms">
              {homepage.graphic2B ? (
                <img src={homepage.graphic2B} alt="Graphic 2B" class="w-full h-full object-cover" />
              ) : (
                <span class="text-gray-700 font-medium text-xs md:text-sm text-center px-2">Graphic Placeholder 2B</span>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 6 -->
    <section class="relative overflow-visible py-12">
      {homepage.section6Title && (
        <div class="flex justify-center px-4 mb-8">
          <div class="w-11/12 md:w-8/12 xl:w-6/12">
            <h2 class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block" data-motion="fade-right">
              {homepage.section6Title}
            </h2>
          </div>
        </div>
      )}
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection6).map((p, i) => (
              <p data-motion="fade-up" style={`animation-delay: ${i * 150}ms`}>{p}</p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Section 7 -->
    <section class="relative overflow-visible pb-12">
      {homepage.section7Title && (
        <div class="flex justify-center px-4 mb-8">
          <div class="w-11/12 md:w-8/12 xl:w-6/12">
            <h2 class="text-3xl md:text-4xl font-black mb-6 text-red-600 border-b-2 border-gray-300 pb-2 inline-block" data-motion="fade-right">
              {homepage.section7Title}
            </h2>
          </div>
        </div>
      )}
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection7).map((p, i) => (
              <p data-motion={i % 2 === 0 ? "fade-left" : "fade-right"} style={`animation-delay: ${(i + 1) * 100}ms`}>{p}</p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Section 8 (Dark) -->
    <section class="relative overflow-visible pb-12 bg-gray-900 text-white py-16 rounded-t-[50px]">
      {homepage.section8Title && (
        <div class="flex justify-center px-4 mb-8">
          <div class="w-11/12 md:w-8/12 xl:w-6/12">
            <h2 class="text-3xl md:text-4xl font-black mb-6 text-white border-b-2 border-yellow-400 pb-2 inline-block" data-motion="fade-right">
              {homepage.section8Title}
            </h2>
          </div>
        </div>
      )}
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div class="text-lg md:text-xl text-gray-300 space-y-6 font-serif leading-relaxed">
            {parseParagraphs(homepage.textSection8).map((p, i) => {
              const isYellow = p.trim().startsWith('“') || p.trim().startsWith('"');
              return (
                <p data-motion={isYellow ? "zoom-in" : "fade-up"} style={`animation-delay: ${100 + (i * 150)}ms`} class={isYellow ? "text-yellow-400 font-medium" : ""}>
                  {p}
                </p>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Footer Message -->
    <section class="relative overflow-visible pb-20 pt-8 border-t border-gray-300 bg-gray-900 text-gray-400">
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12 text-center text-sm space-y-4">
          {parseParagraphs(homepage.footerMessage).map((p, i) => (
            <p data-motion="fade-in" style={`animation-delay: ${200 + (i * 100)}ms`}>{p}</p>
          ))}
        </div>
      </div>
    </section>
  </main>

  <button id="scrollToTopBtn" class="fixed bottom-8 right-8 w-14 h-14 bg-red-600 text-white rounded-full shadow-lg flex items-center justify-center hover:bg-red-700 hover:-translate-y-1 transition-all duration-300 z-50 opacity-0 translate-y-4 pointer-events-none" aria-label="Scroll to top">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <style is:global>
    [data-motion] { opacity: 0; transition-duration: 0.5s; }
    [data-motion="fade-in"] { transition-property: opacity; transition-timing-function: ease-in-out; }
    [data-motion="fade-up"] { transform: translateY(40px); transition-property: opacity, transform; transition-timing-function: cubic-bezier(0.17, 0.55, 0.55, 1); }
    [data-motion="fade-left"] { transform: translateX(40px); transition-property: opacity, transform; transition-timing-function: ease-out; }
    [data-motion="fade-right"] { transform: translateX(-40px); transition-property: opacity, transform; transition-timing-function: ease-out; }
    [data-motion="zoom-in"] { transform: scale(0.9); transition-property: opacity, transform; transition-timing-function: ease-out; }
    [data-motion].is-visible { opacity: 1; transform: none; }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // 1. Intersection Observer for scroll animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            if (el.dataset.delay) el.style.transitionDelay = el.dataset.delay;
            el.classList.add("is-visible");
          } else {
            if (entry.boundingClientRect.top > 0) {
              el.style.transitionDelay = "0ms";
              el.classList.remove("is-visible");
            }
          }
        });
      }, { rootMargin: "0px 0px 50px 0px", threshold: 0 });

      document.querySelectorAll("[data-motion]").forEach((htmlElement) => {
        const el = htmlElement as HTMLElement;
        if (el.style.animationDelay) {
          const ms = parseInt(el.style.animationDelay, 10);
          el.dataset.delay = `${ms * 0.25}ms`;
        }
        observer.observe(el);
      });

      // 2. Scroll to Top Button Logic
      const scrollToTopBtn = document.getElementById("scrollToTopBtn");
      if (scrollToTopBtn) {
        window.addEventListener("scroll", () => {
          if (window.scrollY > 400) {
            scrollToTopBtn.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
            scrollToTopBtn.classList.add("opacity-100", "translate-y-0");
          } else {
            scrollToTopBtn.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
            scrollToTopBtn.classList.remove("opacity-100", "translate-y-0", "hover:-translate-y-1");
          }
        });
        scrollToTopBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      // 3. Character Card Toggle Logic
      const cards = document.querySelectorAll('.character-card');
      cards.forEach(card => {
        const btn = card.querySelector('.toggle-btn');
        const panel = card.querySelector('.story-panel');
        
        if (!btn || !panel) return; // Prevent script crash if elements are missing
        
        card.addEventListener('click', () => {
          panel.classList.toggle('hidden');
          if(panel.classList.contains('hidden')) {
            btn.textContent = 'Baca Cerita';
            btn.classList.remove('bg-gray-800', 'text-white');
          } else {
            btn.textContent = 'Tutup Cerita';
            btn.classList.add('bg-gray-800', 'text-white');
          }
        });
      });
    });
  </script>
</Layout>