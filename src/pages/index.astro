                ))
            }
          </div>

          <div
            class="w-full lg:w-7/12 lg:sticky lg:top-8 h-[400px] sm:h-[450px] bg-gray-50/30 rounded-3xl border border-gray-100 p-8 md:p-12 relative flex items-center justify-center overflow-hidden"
          >
            <div
              class="absolute inset-0 flex items-center justify-center opacity-[0.02] pointer-events-none select-none"
            >
              <span class="text-[12rem] font-serif font-black">ESSAY</span>
            </div>

            <div
              id="story-placeholder"
              class="text-center max-w-xs transition-opacity duration-300 z-10"
            >
              <svg
                class="w-8 h-8 text-gray-300 mx-auto mb-4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
                ></path>
              </svg>
              <p
                class="text-xs font-bold uppercase tracking-widest text-gray-400"
              >
                Pilih salah satu tokoh untuk membaca kisah mereka
              </p>
            </div>

            {
              homepage.characters &&
                homepage.characters.map((char, index) => (
                  <div
                    id={`story-content-${index}`}
                    class="story-content hidden opacity-0 w-full h-full flex flex-col justify-start transform translate-y-4 transition-all duration-500 ease-out z-10"
                  >
                    <div class="flex items-center gap-2 mb-6 shrink-0">
                      <span class={`w-2 h-2 rounded-full ${char.color}`} />
                      <span class="text-xs font-bold uppercase tracking-widest text-gray-400">
                        Catatan Naratif &bull; {char.name}
                      </span>
                    </div>

                    <div class="overflow-y-auto pr-2 pb-6 max-h-[280px] sm:max-h-[320px] scrollbar-none relative">
                      <p class="story-text text-gray-700 font-serif text-lg leading-relaxed antialiased first-letter:text-5xl first-letter:font-black first-letter:text-gray-950 first-letter:mr-3 first-letter:float-left first-letter:font-sans first-letter:leading-none">
                        {char.story}
                      </p>
                    </div>

                    <div class="absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-gray-50/80 to-transparent pointer-events-none rounded-b-3xl" />
                  </div>
                ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Harapan -->
    <section class="relative overflow-visible py-12">
      {
        homepage.section3Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section3Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="editorial-prose text-lg md:text-xl text-gray-800 font-serif leading-relaxed"
            set:html={renderRichText(homepage.textSection3, "section3")}
          />
        </div>
      </div>
    </section>

    <!-- Section 4 -->
    <section class="relative overflow-visible pb-12 bg-stone-50 py-8">
      {
        homepage.section4Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section4Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="editorial-prose text-lg md:text-xl text-gray-800 font-serif leading-relaxed"
            set:html={renderRichText(homepage.textSection4, "section4")}
          />
        </div>
      </div>
    </section>

    <!-- Video Section -->
    <section class="py-8 md:py-16 relative">
      <div class="flex justify-center px-4">
        <div class="w-full md:w-10/12" data-motion="zoom-in">
          <div
            class="relative w-full aspect-video flex items-center justify-center overflow-visible p-4 md:p-8"
          >
            <div
              class="w-full h-full bg-gray-800 border-8 md:border-16 border-[#eccb2f] shadow-2xl rotate-1 flex items-center justify-center group relative overflow-hidden z-10 hover:rotate-0 transition-transform duration-500"
            >
              {
                homepage.videoUrl ? (
                  <iframe
                    class="w-full h-full absolute inset-0 z-20"
                    src={homepage.videoUrl}
                    title="YouTube video player"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  />
                ) : (
                  <div class="w-16 h-16 md:w-24 md:h-24 bg-white/90 rounded-full flex items-center justify-center z-20 group-hover:scale-110 transition-transform cursor-pointer shadow-lg">
                    <div class="ml-2 w-0 h-0 border-t-10 border-t-transparent border-l-16 border-l-red-600 border-b-10 border-b-transparent md:border-t-14 md:border-l-24 md:border-b-14" />
                  </div>
                )
              }
            </div>
            <div
              class="absolute inset-4 md:inset-8 bg-[#eccb2f]/30 -rotate-2 rounded z-0"
              data-motion="fade-in"
              style="animation-delay: 300ms"
            >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5 -->
    <section class="relative overflow-visible pb-12 pt-8">
      {
        homepage.section5Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="zoom-in"
              >
                {homepage.section5Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="editorial-prose text-lg md:text-xl text-gray-800 font-serif leading-relaxed"
            set:html={renderRichText(homepage.textSection5, "section5")}
          />
        </div>
      </div>
    </section>

    <!-- Graphic Placeholder Section (Fixed Single Portrait Layout) -->
    <section class="relative overflow-hidden">
      <div class="flex justify-center px-4 relative z-10">
        <div class="w-full">
          <div
            class="relative w-full h-112 md:h-160 flex items-center justify-center overflow-visible"
          >
            <div
              class="relative w-88 aspect-[4/5] bg-stone-100 border-4 border-gray-900 shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500 ease-out cursor-pointer overflow-hidden z-10"
              data-motion="zoom-in"
              style="animation-delay: 200ms"
            >
              <div class="relative w-full h-full group">
                {
                  homepage.graphic2A ? (
                    <img
                      src={homepage.graphic2A}
                      alt="Graphic Showcase"
                      class="w-full h-full object-cover grayscale-0 md:grayscale contrast-110 md:group-hover:grayscale-0 transition-all duration-700 ease-out"
                    />
                  ) : (
                    <div class="w-full h-full flex flex-col items-center justify-center text-gray-500 font-sans p-6 text-center">
                      <svg
                        class="w-8 h-8 text-gray-400 mb-2"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 017.5 0z"
                        />
                      </svg>
                      <span class="text-xs font-bold uppercase tracking-widest text-gray-400">
                        Graphic 2A
                      </span>
                    </div>
                  )
                }
                <div
                  class="absolute bottom-4 left-4 bg-zinc-900/95 backdrop-blur-xs text-white py-1.5 px-3 text-[9px] font-mono tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xs"
                >
                  {homepage.graphic2ACaption || "Sumber: Jakpat"}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 6 -->
    <section class="relative overflow-visible py-12">
      {
        homepage.section6Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section6Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="editorial-prose text-lg md:text-xl text-gray-800 font-serif leading-relaxed"
            set:html={renderRichText(homepage.textSection6, "section6")}
          />
        </div>
      </div>
    </section>

    <!-- Section 7 -->
    <section class="relative overflow-visible pb-12">
      {
        homepage.section7Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-red-600 border-b-2 border-gray-300 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section7Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="editorial-prose text-lg md:text-xl text-gray-800 font-serif leading-relaxed"
            set:html={renderRichText(homepage.textSection7, "section7")}
          />
        </div>
      </div>
    </section>

    <div id="scroll-tracker" class="h-px w-full clear-both"></div>

    <!-- Section 8 (Dark Mode Wrap) -->
    <section
      class="relative bg-stone-950 text-white py-24 px-4 sm:px-6 rounded-t-[40px] md:rounded-t-[60px] overflow-hidden"
    >
      <div
        class="absolute -right-16 -bottom-16 w-64 h-64 border border-white/5 rounded-full pointer-events-none"
      >
      </div>

      {
        homepage.section8Title && (
          <div class="flex justify-center px-4 mb-12">
            <div class="w-11/12 md:w-8/12 xl:w-6/12 text-center">
              <h2
                class="text-3xl md:text-4xl font-serif font-black tracking-tight mb-2 text-white inline-block"
                data-motion="fade-up"
              >
                {homepage.section8Title}
              </h2>
              <div class="w-12 h-1 bg-yellow-400 mx-auto mt-4 rounded-full" />
            </div>
          </div>
        )
      }

      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <!-- Uses editorial-prose-dark to flip quote colors -->
          <div
            class="editorial-prose editorial-prose-dark text-lg md:text-xl text-stone-300 font-serif leading-relaxed antialiased"
            set:html={renderRichText(homepage.textSection8, "section8")}
          />
        </div>
      </div>
    </section>

    <!-- Dynamic Section: Editorial Credits Board -->
    <section
      class="bg-stone-950 text-stone-400 py-16 border-t border-stone-900 px-4 sm:px-6"
    >
      <div
        class="max-w-4xl mx-auto border border-stone-800 rounded-3xl p-8 md:p-12 bg-stone-900/30 relative overflow-hidden"
        data-motion="fade-up"
      >
        <div
          class="flex items-center gap-3 mb-10 border-b border-stone-800 pb-6"
        >
          <span class="w-1.5 h-3 bg-red-600 rounded-xs"></span>
          <h3
            class="text-xs font-black tracking-widest text-stone-200 uppercase font-sans"
          >
            {homepage.creditsTitle || "Tim Redaksi & Produksi"}
          </h3>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-8 font-sans"
        >
          {
            homepage.creditWriter && (
              <div class="space-y-1">
                <span class="text-[10px] font-bold uppercase tracking-widest text-stone-500 block">
                  Writer
                </span>
                <p class="text-sm font-bold text-stone-200">
                  {homepage.creditWriter}
                </p>
              </div>
            )
          }

          {
            homepage.creditResearcher && (
              <div class="space-y-1">
                <span class="text-[10px] font-bold uppercase tracking-widest text-stone-500 block">
                  Researcher
                </span>
                <p class="text-sm font-bold text-stone-200">
                  {homepage.creditResearcher}
                </p>
              </div>
            )
