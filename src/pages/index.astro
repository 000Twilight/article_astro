              data-motion="fade-left"
              style="animation-delay: 200ms"
            >
              <span class="text-gray-500 font-medium text-xs md:text-sm text-center px-2">Graphic Placeholder Lorem Ipsum 2A</span>
            </div>

            <div
              class="absolute w-52 md:w-80 aspect-3/4 bg-gray-400 border-8 md:border-12 border-[#eccb2f] shadow-2xl -rotate-4 -translate-x-16 -translate-y-4 md:-translate-x-28 md:-translate-y-8 flex items-center justify-center z-20 transition-transform duration-300 hover:scale-105 hover:rotate-2 hover:z-40 cursor-pointer"
              data-motion="fade-right"
              style="animation-delay: 400ms"
            >
              <span class="text-gray-700 font-medium text-xs md:text-sm text-center px-2">Graphic Placeholder Lorem Ipsum 2B</span>
            </div>
          </div>
