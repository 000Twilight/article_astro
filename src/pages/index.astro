---
import Layout from "../layouts/Layout.astro";
import homepage from "../content/homepage/data.json";

// Type definitions for your layout arrays
type TimelineItem = {
  year: string;
  text: string;
  image: string | null;
};

// Explicitly cast the timeline array as TimelineItem[]
const timelineData = (homepage.timeline || []) as TimelineItem[];

const col1Items = timelineData.filter((_, i) => i % 2 === 0);
const col2Items = timelineData.filter((_, i) => i % 2 === 1);

const col1Rotations = ["-rotate-6", "-rotate-2", "-rotate-3", "-rotate-2"];
const col2Rotations = ["rotate-6", "rotate-4", "rotate-6", "rotate-3"];

function parseParagraphs(text: string | null | undefined) {
  return (text || "").split("\n\n").filter((p) => p.trim() !== "");
}
---

<Layout
  title={homepage.coverTitle?.replace("\n", " ")}
  headerTitle={homepage.headerTitle}
>
  <main class="pt-0">
    <!-- Hero & Introduction Combined Layout -->
    <section id="cover-section" class="relative w-full min-h-screen bg-linear-to-br from-zinc-50 to-stone-100 flex items-center pt-24 pb-16 px-4 sm:px-8">
      <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        
        <!-- Left Content Column (7 Columns) -->
        <div class="lg:col-span-7 flex flex-col justify-center" data-motion="fade-right">
          
          <!-- Large Magazine Title Block -->
          <h1 class="text-4xl md:text-6xl font-serif font-black text-red-600 tracking-tight leading-none mb-8">
            {
              homepage.coverTitle
                ?.split("\n")
                .map((line) => <span class="block">{line}</span>)
            }
          </h1>
          
          <div class="w-20 h-2 bg-red-600 mb-8 rounded-full"></div>
          
          <!-- Dynamic Prose Flow -->
          <div class="space-y-6 text-gray-800 font-serif text-lg md:text-xl leading-relaxed antialiased">
            
            <!-- First Paragraph: Demographic Intro (With Dropcap) -->
            <p class="first-letter:text-6xl first-letter:font-sans first-letter:font-black first-letter:text-red-600 first-letter:mr-3 first-letter:float-left first-letter:leading-none">
              {homepage.coverIntro}
            </p>

            <!-- Second Paragraph: The Core Core Dynamics Statement -->
            <p>
              {homepage.textSection1}
            </p>
          </div>
        </div>

        <!-- Right Content Image Frame Column (5 Columns) -->
        <div class="lg:col-span-5 relative flex flex-col items-center lg:sticky lg:top-24" data-motion="zoom-in" style="animation-delay: 200ms">
          <div class="relative w-full max-w-sm aspect-[4/5]">
            <!-- Yellow Offset Frame Shadow -->
            <div class="absolute inset-0 bg-[#eccb2f] border-4 border-gray-900 shadow-lg -rotate-3 translate-x-3 translate-y-3 z-0"></div>
            
            <!-- Core Image Frame -->
            <div class="absolute inset-0 bg-gray-200 border-4 border-gray-900 overflow-hidden rotate-2 group transition-transform duration-500 hover:rotate-0 z-10">
              {
                homepage.coverImage ? (
                  <img
                    src={homepage.coverImage}
                    alt="Cover Story Image"
                    class="w-full h-full object-cover grayscale contrast-110 group-hover:grayscale-0 transition-all duration-700"
                  />
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center text-gray-500 font-sans p-6 text-center">
                    <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 017.5 0z" />
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-widest text-gray-400">Visual Struktur Demografi</span>
                  </div>
                )
              }
            </div>
          </div>

          <!-- Caption Placement: Directly Under Image as requested -->
          <span class="text-xs font-mono uppercase tracking-wider text-gray-400 font-sans mt-8 text-center block border-t border-dashed border-gray-200 pt-4 w-full max-w-sm">
            Sumber data : SUPAS 2025 dan BPS
          </span>
        </div>

      </div>
    </section>
    
    <section class="relative overflow-hidden bg-white py-24 px-4 sm:px-6">
      <div class="max-w-6xl mx-auto">
        
        <div class="mb-20 border-b border-gray-100 pb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div class="max-w-xl">
            <span class="text-xs font-black tracking-widest text-red-500 uppercase block mb-3">// Profil Tokoh</span>
            <h2 class="text-4xl md:text-5xl font-serif font-black tracking-tight text-gray-900">
              {homepage.section2Title}
            </h2>
          </div>
          <div class="max-w-md text-gray-500 font-serif text-base leading-relaxed">
            {parseParagraphs(homepage.textSection2).map((p) => (
              <p class="mb-2 last:mb-0">{p}</p>
            ))}
          </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-12 items-start">
          
          <div class="w-full lg:w-5/12 flex flex-col gap-4">
            {homepage.characters && homepage.characters.map((char, index) => (
              <div 
                class="character-row group relative bg-gray-50/50 hover:bg-gray-50 p-6 rounded-2xl cursor-pointer border border-transparent transition-all duration-300 select-none flex items-center justify-between"
                data-index={index}
              >
                <div class={`absolute left-0 top-1/4 bottom-1/4 w-1 ${char.color} rounded-r-full opacity-0 scale-y-50 transition-all duration-300 group-[.is-active]:opacity-100 group-[.is-active]:scale-y-100 group-[.is-active]:top-4 group-[.is-active]:bottom-4`}></div>
                
                <div class="flex items-center gap-5 pl-2">
                  <div class="w-16 h-16 rounded-xl bg-gray-200 overflow-hidden shrink-0 shadow-xs border border-white transition-transform duration-500 group-hover:scale-105 group-[.is-active]:scale-105">
                    {char.image ? (
                      <img src={char.image} alt={char.name} class="w-full h-full object-cover" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-gray-400 bg-gray-100">
                        <span class="font-serif text-lg font-bold">{char.name[0]}</span>
                      </div>
                    )}
                  </div>
                  
                  <div>
                    <h3 class="text-xl font-bold text-gray-900 tracking-tight group-hover:text-gray-950">
                      {char.name} <span class="text-sm font-normal text-gray-400 font-serif">, {char.age}</span>
                    </h3>
                    <p class="text-xs font-semibold tracking-wider text-gray-400 uppercase mt-0.5">{char.job}</p>
                  </div>
                </div>

                <div class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center transition-all duration-300 bg-white group-hover:border-gray-400 group-[.is-active]:bg-gray-900 group-[.is-active]:border-gray-900 group-[.is-active]:text-white">
                  <svg class="w-4 h-4 transform transition-transform duration-500 -rotate-45 group-[.is-active]:rotate-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
                  </svg>
                </div>
              </div>
            ))}
          </div>

          <div class="w-full lg:w-7/12 lg:sticky lg:top-8 h-[400px] sm:h-[450px] bg-gray-50/30 rounded-3xl border border-gray-100 p-8 md:p-12 relative flex items-center justify-center overflow-hidden">
            
            <div class="absolute inset-0 flex items-center justify-center opacity-[0.02] pointer-events-none select-none">
              <span class="text-[12rem] font-serif font-black">ESSAY</span>
            </div>

            <div id="story-placeholder" class="text-center max-w-xs transition-opacity duration-300 z-10">
              <svg class="w-8 h-8 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"></path></svg>
              <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Pilih salah satu tokoh untuk membaca kisah mereka</p>
            </div>

            {homepage.characters && homepage.characters.map((char, index) => (
              <div 
                id={`story-content-${index}`} 
                class="story-content hidden opacity-0 w-full h-full flex flex-col justify-start transform translate-y-4 transition-all duration-500 ease-out z-10"
              >
                <div class="flex items-center gap-2 mb-6 shrink-0">
                  <span class={`w-2 h-2 rounded-full ${char.color}`}></span>
                  <span class="text-xs font-bold uppercase tracking-widest text-gray-400">Catatan Naratif &bull; {char.name}</span>
                </div>
                
                <div class="overflow-y-auto pr-2 pb-6 max-h-[280px] sm:max-h-[320px] scrollbar-none relative">
                  <p class="story-text text-gray-700 font-serif text-lg leading-relaxed antialiased first-letter:text-5xl first-letter:font-black first-letter:text-gray-950 first-letter:mr-3 first-letter:float-left first-letter:font-sans first-letter:leading-none">
                    {char.story}
                  </p>
                </div>

                <div class="absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-gray-50/80 to-transparent pointer-events-none rounded-b-3xl"></div>
              </div>
            ))}

          </div>

        </div>
      </div>
    </section>

    {
      homepage.showTimeline && timelineData.length > 0 && (
        <section class="py-12 md:py-20 relative overflow-hidden mt-8 mb-12 flex justify-center px-4">
          <div
            class="relative w-full md:w-4/5 lg:w-[60%] max-w-4xl border-4 border-red-600 rounded-[100px] md:rounded-[150px] pt-16 md:pt-24 pb-20 md:pb-28 flex flex-col items-center z-10"
            data-motion="zoom-in"
          >
            <div class="absolute inset-2 md:inset-3 border-2 border-red-600 rounded-[90px] md:rounded-[140px] pointer-events-none z-0" />

            <div
              class="relative z-10 px-6 md:px-12 text-center max-w-3xl mb-12"
              data-motion="fade-up"
              style="animation-delay: 200ms"
            >
              <div class="flex justify-center items-center space-x-2">
                <span class="block w-12 h-1 bg-red-600 rounded-full" />
                <span class="block w-3 h-3 border-2 border-red-600 rounded-full" />
                <span class="block w-12 h-1 bg-red-600 rounded-full" />
              </div>
            </div>

            <div class="w-full relative flex pb-12 z-10">
              <div
                class="absolute left-1/2 -translate-x-1/2 top-0 bottom-12 md:bottom-20 w-1 bg-red-600 z-0"
                data-motion="fade-in"
                style="animation-delay: 400ms"
              />

              <div class="w-1/2 flex flex-col items-end gap-y-16 md:gap-y-24">
                {col1Items.map((item, index) => {
                  const rotation = col1Rotations[index % col1Rotations.length];
                  return (
                    <div
                      class="flex flex-col items-center w-full sm:w-11/12 max-w-[320px] md:max-w-[380px]"
                      data-motion="fade-right"
                      style={`animation-delay: ${100 + index * 200}ms`}
                    >
                      <div class="relative w-full max-w-[260px] h-40 md:h-56 mb-6 flex justify-center items-center">
                        <div class={`absolute z-20 w-40 md:w-48 aspect-[4/3] bg-gray-300 border-[4px] md:border-[6px] border-[#eccb2f] ${rotation} shadow-lg flex items-center justify-center overflow-hidden transition-all duration-300 hover:rotate-0 hover:scale-105`}>
                          {item.image ? (
                            <img
                              src={item.image}
                              alt={item.year}
                              class="w-full h-full object-cover"
                            />
                          ) : (
                            <span class="text-[10px] md:text-xs text-gray-600 font-medium text-center">
                              Image
                            </span>
                          )}
                        </div>
                      </div>
                      <div class="flex w-full items-center">
                        <div class="flex-1" />
                        <h3 class="text-3xl md:text-4xl font-black text-red-600 tracking-tight px-4 md:px-6">
                          {item.year}
                        </h3>
                        <div class="flex-1 h-1 bg-red-600 z-10" />
                      </div>
                      <div class="w-3 md:w-4 h-3 md:h-4 bg-red-600 rounded-full mt-2 mb-4" />
                      <div class="text-center px-4 space-y-3 text-sm md:text-base font-medium text-gray-900 leading-snug">
                        <p>{item.text}</p>
                      </div>
                    </div>
                  );
                })}
              </div>

              <div class="w-1/2 flex flex-col items-start gap-y-16 md:gap-y-24 pt-[14rem] md:pt-[20rem]">
                {col2Items.map((item, index) => {
                  const rotation = col2Rotations[index % col2Rotations.length];
                  return (
                    <div
                      class="flex flex-col items-center w-full sm:w-11/12 max-w-[320px] md:max-w-[380px]"
                      data-motion="fade-left"
                      style={`animation-delay: ${200 + index * 200}ms`}
                    >
                      <div class="relative w-full max-w-[260px] h-40 md:h-56 mb-6 flex justify-center items-center">
                        <div class={`absolute z-20 w-40 md:w-48 aspect-[4/3] bg-gray-300 border-[4px] md:border-[6px] border-[#eccb2f] ${rotation} shadow-lg flex items-center justify-center overflow-hidden transition-all duration-300 hover:rotate-0 hover:scale-105`}>
                          {item.image ? (
                            <img
                              src={item.image}
                              alt={item.year}
                              class="w-full h-full object-cover"
                            />
                          ) : (
                            <span class="text-[10px] md:text-xs text-gray-600 font-medium text-center">
                              Image
                            </span>
                          )}
                        </div>
                      </div>
                      <div class="flex w-full items-center">
                        <div class="flex-1 h-1 bg-red-600 z-10" />
                        <h3 class="text-3xl md:text-4xl font-black text-red-600 tracking-tight px-4 md:px-6">
                          {item.year}
                        </h3>
                        <div class="flex-1" />
                      </div>
                      <div class="w-3 md:w-4 h-3 md:h-4 bg-red-600 rounded-full mt-2 mb-4" />
                      <div class="text-center px-4 space-y-3 text-sm md:text-base font-medium text-gray-900 leading-snug">
                        <p>{item.text}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </section>
      )
    }

    <section class="relative overflow-visible pb-12 pt-8">
      {
        homepage.section3Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section3Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed"
          >
            {
              parseParagraphs(homepage.textSection3).map((p, i) => {
                const isQuote = p.trim().startsWith("“") || p.trim().startsWith('"');
                return (
                  <p
                    data-motion="fade-up"
                    style={`animation-delay: ${50 + i * 100}ms`}
                    class={isQuote ? "italic text-gray-600 pl-4 border-l-4 border-red-500" : ""}
                  >
                    {p}
                  </p>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-8 md:py-16 relative">
      <div class="flex justify-center px-4">
        <div class="w-full md:w-10/12" data-motion="zoom-in">
          <div
            class="relative w-full aspect-video flex items-center justify-center overflow-visible p-4 md:p-8"
          >
            <div
              class="w-full h-full bg-gray-800 border-8 md:border-16 border-[#eccb2f] shadow-2xl rotate-1 flex items-center justify-center group relative overflow-hidden z-10 hover:rotate-0 transition-transform duration-500"
            >
              {
                homepage.videoUrl ? (
                  <iframe
                    class="w-full h-full absolute inset-0 z-20"
                    src={homepage.videoUrl}
                    title="YouTube video player"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  />
                ) : (
                  <div class="w-16 h-16 md:w-24 md:h-24 bg-white/90 rounded-full flex items-center justify-center z-20 group-hover:scale-110 transition-transform cursor-pointer shadow-lg">
                    <div class="ml-2 w-0 h-0 border-t-10 border-t-transparent border-l-16 border-l-red-600 border-b-10 border-b-transparent md:border-t-14 md:border-l-24 md:border-b-14" />
                  </div>
                )
              }
            </div>
            <div
              class="absolute inset-4 md:inset-8 bg-[#eccb2f]/30 -rotate-2 rounded z-0"
              data-motion="fade-in"
              style="animation-delay: 300ms"
            >
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-visible pb-12 bg-stone-50 py-8">
      {
        homepage.section4Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section4Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed"
          >
            {
              parseParagraphs(homepage.textSection4).map((p, i) => {
                const borderColors = [
                  "",
                  "text-red-600 font-semibold",
                  "text-blue-600 font-semibold",
                  "",
                  "",
                  "text-emerald-600 font-semibold",
                  "text-stone-600 font-semibold",
                ];
                return (
                  <p
                    data-motion="fade-left"
                    style={`animation-delay: ${i * 150}ms`}
                    class={borderColors[i] ? `pl-6 ${borderColors[i]}` : ""}
                  >
                    {p}
                  </p>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-visible pb-12 pt-8">
      {
        homepage.section5Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="zoom-in"
              >
                {homepage.section5Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed"
          >
            {
              parseParagraphs(homepage.textSection5).map((p, i) => {
                const hasBg = p.trim().startsWith("“") || p.trim().startsWith('"');
                const extraClass = hasBg && p.includes("eros laoreet")
                    ? "font-medium bg-yellow-50 p-4 rounded-md shadow-sm border-l-4 border-yellow-500"
                    : "";
                return (
                  <p
                    data-motion="zoom-in"
                    style={`animation-delay: ${(i + 1) * 100}ms`}
                    class={extraClass}
                  >
                    {p}
                  </p>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-8 md:py-16 relative bg-zinc-100/60 overflow-hidden">
      <div class="flex justify-center px-4">
        <div class="w-full md:w-10/12">
          <div
            class="relative w-full h-100 md:h-150 flex items-center justify-center overflow-visible"
          >
            <div
              class="absolute w-64 h-64 md:w-125 md:h-125 bg-yellow-100 rounded-full flex items-center justify-center z-0 animate-pulse"
            >
            </div>
            <div
              class="absolute bottom-20 left-10 w-24 h-24 md:w-32 md:h-32 bg-green-500 rounded-tl-full rounded-br-full rotate-15 opacity-70 z-0"
            >
            </div>

            <div
              class="absolute w-56 md:w-96 aspect-4/3 bg-gray-300 border-8 md:border-12 border-[#eccb2f] shadow-lg rotate-4 translate-x-12 translate-y-10 md:translate-x-20 md:translate-y-16 flex items-center justify-center z-10 transition-transform duration-300 hover:scale-105 hover:-rotate-2 hover:z-40 cursor-pointer overflow-hidden"
              data-motion="fade-left"
              style="animation-delay: 200ms"
            >
              {
                homepage.graphic2A ? (
                  <img
                    src={homepage.graphic2A}
                    alt="Graphic 2A"
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <span class="text-gray-500 font-medium text-xs md:text-sm text-center px-2">
                    Graphic Placeholder 2A
                  </span>
                )
              }
            </div>

            <div
              class="absolute w-52 md:w-80 aspect-3/4 bg-gray-400 border-8 md:border-12 border-[#eccb2f] shadow-2xl -rotate-4 -translate-x-16 -translate-y-4 md:-translate-x-28 md:-translate-y-8 flex items-center justify-center z-20 transition-transform duration-300 hover:scale-105 hover:rotate-2 hover:z-40 cursor-pointer overflow-hidden"
              data-motion="fade-right"
              style="animation-delay: 400ms"
            >
              {
                homepage.graphic2B ? (
                  <img
                    src={homepage.graphic2B}
                    alt="Graphic 2B"
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <span class="text-gray-700 font-medium text-xs md:text-sm text-center px-2">
                    Graphic Placeholder 2B
                  </span>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-visible py-12">
      {
        homepage.section6Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-gray-900 border-b-2 border-red-500 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section6Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed"
          >
            {
              parseParagraphs(homepage.textSection6).map((p, i) => (
                <p data-motion="fade-up" style={`animation-delay: ${i * 150}ms`}>
                  {p}
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-visible pb-12">
      {
        homepage.section7Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-red-600 border-b-2 border-gray-300 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section7Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="text-lg md:text-xl text-gray-800 space-y-6 font-serif leading-relaxed"
          >
            {
              parseParagraphs(homepage.textSection7).map((p, i) => (
                <p
                  data-motion={i % 2 === 0 ? "fade-left" : "fade-right"}
                  style={`animation-delay: ${(i + 1) * 100}ms`}
                >
                  {p}
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section
      class="relative overflow-visible pb-12 bg-gray-900 text-white py-16 rounded-t-[50px]"
    >
      {
        homepage.section8Title && (
          <div class="flex justify-center px-4 mb-8">
            <div class="w-11/12 md:w-8/12 xl:w-6/12">
              <h2
                class="text-3xl md:text-4xl font-black mb-6 text-white border-b-2 border-yellow-400 pb-2 inline-block"
                data-motion="fade-right"
              >
                {homepage.section8Title}
              </h2>
            </div>
          </div>
        )
      }
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12">
          <div
            class="text-lg md:text-xl text-gray-300 space-y-6 font-serif leading-relaxed"
          >
            {
              parseParagraphs(homepage.textSection8).map((p, i) => {
                const isYellow = p.trim().startsWith("“") || p.trim().startsWith('"');
                return (
                  <p
                    data-motion={isYellow ? "zoom-in" : "fade-up"}
                    style={`animation-delay: ${100 + i * 150}ms`}
                    class={isYellow ? "text-yellow-400 font-medium" : ""}
                  >
                    {p}
                  </p>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <section
      class="relative overflow-visible pb-20 pt-12 border-t border-gray-800 bg-gray-900 text-gray-400"
    >
      <div class="flex justify-center px-4">
        <div class="w-11/12 md:w-8/12 xl:w-6/12 text-center text-sm space-y-8">
          <div class="space-y-4 text-gray-300 font-medium tracking-wide">
            {
              parseParagraphs(homepage.footerMessage).map((p, i) => (
                <p data-motion="fade-in" style={`animation-delay: ${200 + i * 100}ms`}>
                  {p}
                </p>
              ))
            }
          </div>

          <div
            class="w-24 h-px bg-gray-700 mx-auto"
            data-motion="fade-in"
            style="animation-delay: 300ms"
          >
          </div>

          <div
            class="space-y-3 text-xs text-gray-500 font-sans"
            data-motion="fade-in"
            style="animation-delay: 400ms"
          >
            {
              homepage.creditsText && (
                <p>
                  <span class="font-semibold text-gray-400">Credits:</span>{" "}
                  {homepage.creditsText}
                </p>
              )
            }

            {
              homepage.aiDisclaimer && (
                <p>
                  <span class="font-semibold text-gray-400">Disclaimer:</span>{" "}
                  {homepage.aiDisclaimer}
                </p>
              )
            }

            <p class="pt-4">
              &copy; {new Date().getFullYear()} Tiga Cerita, Satu Realitas. All rights reserved.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <button
    id="scrollToTopBtn"
    class="fixed bottom-8 right-8 w-14 h-14 bg-red-600 text-white rounded-full shadow-lg flex items-center justify-center hover:bg-red-700 hover:-translate-y-1 transition-all duration-300 z-50 opacity-0 translate-y-4 pointer-events-none"
    aria-label="Scroll to top"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"></path>
    </svg>
  </button>

  <style is:global>
    [data-motion] {
      opacity: 0;
      transition-duration: 0.5s;
    }
    [data-motion="fade-in"] {
      transition-property: opacity;
      transition-timing-function: ease-in-out;
    }
    [data-motion="fade-up"] {
      transform: translateY(40px);
      transition-property: opacity, transform;
      transition-timing-function: cubic-bezier(0.17, 0.55, 0.55, 1);
    }
    [data-motion="fade-left"] {
      transform: translateX(40px);
      transition-property: opacity, transform;
      transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    }
    [data-motion="fade-right"] {
      transform: translateX(-40px);
      transition-property: opacity, transform;
      transition-timing-function: ease-out;
    }
    [data-motion="zoom-in"] {
      transform: scale(0.9);
      transition-property: opacity, transform;
      transition-timing-function: ease-out;
    }
    [data-motion].is-visible {
      opacity: 1;
      transform: none;
    }
    .scrollbar-none::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-none {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // 1. Intersection Observer for scroll animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const el = entry.target as HTMLElement;
            if (entry.isIntersecting) {
              if (el.dataset.delay) el.style.transitionDelay = el.dataset.delay;
              el.classList.add("is-visible");
            } else {
              if (entry.boundingClientRect.top > 0) {
                el.style.transitionDelay = "0ms";
                el.classList.remove("is-visible");
              }
            }
          });
        },
        { rootMargin: "0px 0px 50px 0px", threshold: 0 },
      );

      document.querySelectorAll("[data-motion]").forEach((htmlElement) => {
        const el = htmlElement as HTMLElement;
        if (el.style.animationDelay) {
          const ms = parseInt(el.style.animationDelay, 10);
          el.dataset.delay = `${ms * 0.25}ms`;
        }
        observer.observe(el);
      });

      // 2. Scroll to Top Button Logic
      const scrollToTopBtn = document.getElementById("scrollToTopBtn");
      if (scrollToTopBtn) {
        window.addEventListener("scroll", () => {
          if (window.scrollY > 400) {
            scrollToTopBtn.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
            scrollToTopBtn.classList.add("opacity-100", "translate-y-0");
          } else {
            scrollToTopBtn.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
            scrollToTopBtn.classList.remove("opacity-100", "translate-y-0", "hover:-translate-y-1");
          }
        });

        scrollToTopBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      // 3. Split Layout Character Narrative Logic
      const rows = document.querySelectorAll('.character-row');
      const placeholder = document.getElementById('story-placeholder');
      const storyContents = document.querySelectorAll('.story-content');

      rows.forEach(row => {
        row.addEventListener('click', () => {
          const targetIndex = row.getAttribute('data-index');
          const targetContent = document.getElementById(`story-content-${targetIndex}`);
          
          if (row.classList.contains('is-active')) {
            row.classList.remove('is-active');
            if (targetContent) {
              targetContent.classList.add('opacity-0', 'translate-y-4');
              setTimeout(() => targetContent.classList.add('hidden'), 300);
            }
            placeholder?.classList.remove('hidden', 'opacity-0');
            return;
          }

          rows.forEach(r => r.classList.remove('is-active'));
          storyContents.forEach(content => {
            content.classList.add('hidden', 'opacity-0', 'translate-y-4');
          });

          row.classList.add('is-active');
          placeholder?.classList.add('hidden');

          if (targetContent) {
            targetContent.classList.remove('hidden');
            
            const scrollableArea = targetContent.querySelector('.overflow-y-auto');
            if (scrollableArea) scrollableArea.scrollTop = 0;

            requestAnimationFrame(() => {
              targetContent.classList.remove('opacity-0', 'translate-y-4');
            });
          }
        });
      });
    });
  </script>
</Layout>