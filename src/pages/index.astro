  <script is:inline>
  import { animate, inView } from "motion";

  document.querySelectorAll("[data-motion]").forEach((htmlElement) => {
    const el = htmlElement;

    // Initial state
    const animationType = el.getAttribute("data-motion");

    if (animationType === "fade-up") {
      el.style.opacity = "0";
      el.style.transform = "translateY(40px)";
    } else if (animationType === "fade-in") {
      el.style.opacity = "0";
    } else if (animationType === "zoom-in") {
      el.style.opacity = "0";
      el.style.transform = "scale(0.9)";
    } else if (animationType === "fade-right") {
      el.style.opacity = "0";
      el.style.transform = "translateX(-40px)";
    }

    // Animate on view
    inView(
      el,
      () => {
        const delayStr = el.style.animationDelay;
        const delay = delayStr ? parseFloat(delayStr) / 1000 : 0;

        if (animationType === "fade-up") {
          animate(
            el,
            {
              opacity: 1,
              transform: "translateY(0px)",
            },
            {
              duration: 0.8,
              delay,
              easing: [0.17, 0.55, 0.55, 1],
            }
          );
        } else if (animationType === "fade-in") {
          animate(
            el,
            {
              opacity: 1,
            },
            {
              duration: 0.8,
              delay,
              easing: "ease-in-out",
            }
          );
        } else if (animationType === "zoom-in") {
          animate(
            el,
            {
              opacity: 1,
              transform: "scale(1)",
            },
            {
              duration: 0.8,
              delay,
              easing: "ease-out",
            }
          );
        } else if (animationType === "fade-right") {
          animate(
            el,
            {
              opacity: 1,
              transform: "translateX(0px)",
            },
            {
              duration: 0.8,
              delay,
              easing: "ease-out",
            }
          );
        }
      },
      {
        margin: "-50px",
