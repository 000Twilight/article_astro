---
import Layout from "../layouts/Layout.astro";
import homepage from "../content/homepage/data.json";

// Type definitions for your layout arrays
type TimelineItem = {
  year: string;
  text: string;
  image: string | null;
};

// Explicitly cast the timeline array as TimelineItem[]
const timelineData = (homepage.timeline || []) as TimelineItem[];

const col1Items = timelineData.filter((_, i) => i % 2 === 0);
const col2Items = timelineData.filter((_, i) => i % 2 === 1);

const col1Rotations = ["-rotate-6", "-rotate-2", "-rotate-3", "-rotate-2"];
const col2Rotations = ["rotate-6", "rotate-4", "rotate-6", "rotate-3"];

function renderInlineMarkdown(text: string | null | undefined) {
  if (!text) return "";

  return text
    .replace(/\*\*(.*?)\*\*/gim, "<strong>$1</strong>")
    .replace(/\*(.*?)\*/gim, "<em>$1</em>");
}

// Custom Lightweight Markdown Parser for Astro
function renderRichText(
  text: string | null | undefined,
  sectionId: string = "default",
) {
  if (!text) return "";

  // Parse Bold and Italic formatting from Decap CMS
  let parsed = text
    .replace(/\*\*(.*?)\*\*/gim, "<strong>$1</strong>")
    .replace(/\*(.*?)\*/gim, "<em>$1</em>");

  // Split into paragraphs
  const paragraphs = parsed.split("\n\n").filter((p) => p.trim() !== "");

  return paragraphs
    .map((p, index) => {
      // Handle Blockquotes (CMS outputs "> text")
      if (p.trim().startsWith(">")) {
        const cleanQuote = p.replace(/^>\s?/gm, "");
        return `<blockquote data-motion="fade-up" style="animation-delay: ${100 + index * 100}ms"><p>${cleanQuote}</p></blockquote>`;
      }

      // Handle specific section layout logic
      let classes = "";
      let motion = "fade-up";

      // Section 7 Alternate Scroll Direction Animation
      if (sectionId === "section7") {
        motion = index % 2 === 0 ? "fade-left" : "fade-right";
      }

      return `<p class="${classes}" data-motion="${motion}" style="animation-delay: ${100 + index * 100}ms">${p}</p>`;
    })
    .join("");
}
---

<Layout
  title={homepage.coverTitle?.replace("\n", " ")}
  headerTitle={homepage.headerTitle}
>
  <main class="pt-0">
    <!-- Hero & Introduction Combined Layout -->
    <section
      id="cover-section"
      class="relative w-full min-h-screen bg-linear-to-br from-zinc-50 to-stone-100 flex items-center pt-24 pb-16 px-4 sm:px-8"
    >
      <div
        class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start"
      >
        <!-- Left Content Column -->
        <div
          class="lg:col-span-7 flex flex-col justify-center"
          data-motion="fade-right"
        >
          <h1
            class="text-4xl md:text-6xl font-serif font-black text-red-600 tracking-tight leading-none mb-8"
          >
            {
              homepage.coverTitle
                ?.split("\n")
                .map((line) => (
                  <span class="block" set:html={renderInlineMarkdown(line)} />
                ))
            }
          </h1>

          <div class="w-20 h-2 bg-red-600 mb-8 rounded-full"></div>

          <!-- Dynamic Prose Flow -->
          <div
            class="editorial-prose text-gray-800 font-serif text-lg md:text-xl leading-relaxed antialiased"
          >
            <p
              class="first-letter:text-6xl first-letter:font-sans first-letter:font-black first-letter:text-red-600 first-letter:mr-3 first-letter:float-left first-letter:leading-none mb-6"
            >
              {homepage.coverIntro}
            </p>
            <div set:html={renderRichText(homepage.textSection1, "section1")} />
          </div>
        </div>

        <!-- Right Content Image Frame Column -->
        <div
          class="lg:col-span-5 relative flex flex-col items-center lg:sticky lg:top-24"
          data-motion="zoom-in"
          style="animation-delay: 200ms"
        >
          <div class="relative w-full max-w-sm aspect-[4/5]">
            <div
              class="absolute inset-0 bg-[#eccb2f] border-4 border-gray-900 shadow-lg -rotate-3 translate-x-3 translate-y-3 z-0"
            >
            </div>

            <div
              class="absolute inset-0 bg-gray-200 border-4 border-gray-900 overflow-hidden rotate-2 group transition-transform duration-500 hover:rotate-0 z-10"
            >
              {
                homepage.coverImage ? (
                  <img
                    src={homepage.coverImage}
                    alt="Cover Story Image"
                    class="w-full h-full object-cover grayscale-0 md:grayscale contrast-110 md:group-hover:grayscale-0 transition-all duration-700"
                  />
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center text-gray-500 font-sans p-6 text-center">
                    <svg
                      class="w-8 h-8 text-gray-400 mb-2"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 017.5 0z"
                      />
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-widest text-gray-400">
                      Visual Struktur Demografi
                    </span>
                  </div>
                )
              }
            </div>
          </div>

          <span
            class="text-xs uppercase tracking-wider text-gray-400 font-sans mt-8 text-center block border-t border-dashed border-gray-200 pt-4 w-full max-w-sm"
          >
            {homepage.coverCaption}
          </span>
        </div>
      </div>
    </section>

    <!-- Section 2: Character Introductions -->
    <section class="relative overflow-hidden bg-white py-24 px-4 sm:px-6">
      <div class="max-w-6xl mx-auto">
        <div
          class="mb-20 border-b border-gray-100 pb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6"
        >
          <div class="max-w-xl">
            <span
              class="text-xs font-black tracking-widest text-red-500 uppercase block mb-3"
              >// Profil Tokoh</span
            >
            <h2
              class="text-4xl md:text-5xl font-serif font-black tracking-tight text-gray-900"
            >
              {homepage.section2Title}
            </h2>
          </div>
          <div
            class="editorial-prose max-w-md text-gray-500 font-serif text-base leading-relaxed"
            set:html={renderRichText(homepage.textSection2, "section2")}
          />
        </div>

        <div class="flex flex-col lg:flex-row gap-12 items-start">
          <div class="w-full lg:w-5/12 flex flex-col gap-4">
            {
              homepage.characters &&
                homepage.characters.map((char, index) => (
                  <div
                    class="character-row group relative bg-gray-50/50 hover:bg-gray-50 p-6 rounded-2xl cursor-pointer border border-transparent transition-all duration-300 select-none flex items-center justify-between"
                    data-index={index}
                  >
                    <div
                      class={`absolute left-0 top-1/4 bottom-1/4 w-1 ${char.color} rounded-r-full opacity-0 scale-y-50 transition-all duration-300 group-[.is-active]:opacity-100 group-[.is-active]:scale-y-100 group-[.is-active]:top-4 group-[.is-active]:bottom-4`}
                    />
                    <div class="flex items-center gap-5 pl-2">
                      <div class="w-16 h-16 rounded-xl bg-gray-200 overflow-hidden shrink-0 shadow-xs border border-white transition-transform duration-500 group-hover:scale-105 group-[.is-active]:scale-105">
                        {char.image ? (
                          <img
                            src={char.image}
                            alt={char.name}
                            class="w-full h-full object-cover"
                          />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-gray-400 bg-gray-100">
                            <span class="font-serif text-lg font-bold">
                              {char.name[0]}
                            </span>
                          </div>
                        )}
                      </div>
                      <div>
                        <h3 class="text-xl font-bold text-gray-900 tracking-tight group-hover:text-gray-950">
                          {char.name}{" "}
                          <span class="text-sm font-normal text-gray-400 font-serif">
                            , {char.age}
                          </span>
                        </h3>
                        <p class="text-xs font-semibold tracking-wider text-gray-400 uppercase mt-0.5">
                          {char.job}
                        </p>
                      </div>
                    </div>
                    <div class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center transition-all duration-300 bg-white group-hover:border-gray-400 group-[.is-active]:bg-gray-900 group-[.is-active]:border-gray-900 group-[.is-active]:text-white">
                      <svg
                        class="w-4 h-4 transform transition-transform duration-500 -rotate-45 group-[.is-active]:rotate-0"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                        />
                      </svg>
                    </div>
